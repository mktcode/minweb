<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.min.css">
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">

  {{> header}}

  <main class="flex-1">

    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 py-24 text-center">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-6">
        {{hero.title}}
      </h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-8">
        {{hero.subtitle}}
      </p>
      <div class="flex justify-center gap-4">
        <a href="#" class="bg-black text-white px-6 py-3 rounded-lg text-sm font-medium shadow-sm hover:shadow-md transition">
          {{hero.primaryCta}}
        </a>
        <a href="#" class="px-6 py-3 rounded-lg text-sm font-medium bg-white shadow-sm hover:shadow-md transition">
          {{hero.secondaryCta}}
        </a>
      </div>
    </section>

    <!-- Features -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {{#each features}}
          <div class="bg-white rounded-xl p-6 shadow-xl hover:shadow-2xl transition">
            <h3 class="font-medium mb-2">{{title}}</h3>
            <p class="text-sm text-gray-500">{{description}}</p>
          </div>
        {{/each}}
      </div>
    </section>

    <!-- Products -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-semibold mb-2">{{productsHeading}}</h2>
        <p class="text-gray-500 text-sm">{{productsSubheading}}</p>
      </div>

      {{> products products=products}}
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto px-6 py-20 text-center">
      <div class="bg-white rounded-2xl shadow-xl p-10">
        <h2 class="text-2xl font-semibold mb-4">{{cta.title}}</h2>
        <p class="text-gray-500 mb-6">{{cta.subtitle}}</p>
        <a href="#" class="bg-black text-white px-6 py-3 rounded-lg text-sm font-medium shadow-sm hover:shadow-md transition">
          {{cta.button}}
        </a>
      </div>
    </section>

  </main>

  {{> footer}}

</body>
</html>